              <!-- Multi State Compliance Capability: x=361, y=362 -->
              <circle cx="361" cy="362" r="6" fill="#B8341B" opacity="0.5"/>
              <text x="374" y="366" font-family="var(--sans)" font-size="11" fill="#0B1F3A" opacity="0.7">Multi State Compliance Capability</text>

              <!-- Reliable Payroll Processing: x=316, y=371 -->
              <circle cx="316" cy="371" r="6" fill="#B8341B" opacity="0.5"/>
              <text x="329" y="375" font-family="var(--sans)" font-size="11" fill="#0B1F3A" opacity="0.7">Reliable Payroll Processing</text>

              <!-- Benefits Enrollment Improvement: x=201, y=425 -->
              <circle cx="201" cy="425" r="6" fill="#B8341B" opacity="0.5"/>
              <text x="214" y="429" font-family="var(--sans)" font-size="11" fill="#0B1F3A" opacity="0.7">Benefits Enrollment Improvement</text>
            </svg>
          </div>
        </div>
        <div class="deliverable">
          <div class="deliverable-text">
