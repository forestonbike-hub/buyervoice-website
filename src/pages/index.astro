---
import Base from '../layouts/Base.astro';
---

<Base
  title="BuyerVoice.AI — Buyer insights from real conversations"
  description="Hundreds of interviews. Market intelligence for marketing, product, and sales teams."
>
  <!-- Nav -->
  <nav class="nav" aria-label="Primary navigation">
    <div class="nav-inner">
      <a href="/" class="nav-logo" aria-label="BuyerVoice.AI home">
        <img src="/images/logo.svg" alt="BuyerVoice.AI" width="240" height="48" />
      </a>
      <div class="nav-links">
        <a href="#deliverables" class="nav-link">Services</a>
        <a href="#method" class="nav-link">Methodology</a>
        <a href="#about" class="nav-link">About</a>
      </div>
    </div>
  </nav>

  <!-- 1. Hero -->
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <h1 class="hero-headline">Buyer insights from real conversations.</h1>
        <p class="hero-sub">
          Hundreds of interviews. Market intelligence for marketing, product, and sales teams.
        </p>
        <div class="hero-rule"></div>
      </div>
      <div class="hero-illustration">
        <img src="/images/hero-illustration.svg" alt="Interview data visualization showing patterns across hundreds of buyer conversations" width="700" height="400" loading="eager" />
      </div>
    </div>
  </section>

  <!-- 2. The Problem — dark band -->
  <section class="band-dark" id="problem">
    <div class="container">
      <span class="eyebrow eyebrow--light">The problem</span>
      <h2 class="section-heading heading--light section-heading--wide">Flying blind is the norm, and costly.</h2>

      <div class="stats-grid">
        <div class="stat-card">
          <p class="stat-context">Among 353 startups,</p>
          <p class="stat-number">42%</p>
          <p class="stat-detail">of <strong>product failures</strong> traced to "no market need"</p>
          <p class="stat-source">CB Insights</p>
        </div>

        <div class="stat-card">
          <p class="stat-context">Among 1,600 companies,</p>
          <p class="stat-number">80%</p>
          <p class="stat-detail"><strong>did not</strong> have pricing discussions with customers early in product development</p>
          <p class="stat-source">Simon-Kucher &amp; Partners</p>
        </div>

        <div class="stat-card">
          <p class="stat-context">Companies <strong>without</strong> strong insights capabilities are</p>
          <p class="stat-number">88%</p>
          <p class="stat-detail"><strong>less likely</strong> to achieve strong revenue growth</p>
          <p class="stat-source">Forrester</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. Our Method — paper background -->
  <section class="section" id="method">
    <div class="container">
      <span class="eyebrow">Our method</span>
      <h2 class="section-heading section-heading--wide">Marketing Science + AI</h2>

      <div class="method-capabilities">
        <div class="capability">
          <span class="capability-number">1</span>
          <p>Apply PhD-level marketing science to conversational data</p>
        </div>

        <div class="capability">
          <span class="capability-number">2</span>
          <p>Leverage AI to organize and analyze unstructured data</p>
        </div>

        <div class="capability">
          <span class="capability-number">3</span>
          <p>Deliver results in weeks, not months</p>
        </div>

        <div class="capability">
          <span class="capability-number">4</span>
          <p>Provide insights that drive marketing, product, and sales strategy</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. What You Get — warm tint band -->
  <section class="band-warm" id="deliverables">
    <div class="container">
      <span class="eyebrow">What you get</span>
      <h2 class="section-heading section-heading--wide">Insights that drive growth.</h2>
      <p class="section-intro">
        Our research methods and deliverables are structured around the insights that our stakeholders need. We apply frameworks and analyses that are grounded in decades of marketing science.
      </p>

      <div class="deliverables-list">
        <div class="deliverable">
          <div class="deliverable-text">
            <h3>Market landscape according to buyers</h3>
            <p>Who are we really competing against?</p>
          </div>
          <div class="deliverable-graphic"></div>
        </div>
        <div class="deliverable">
          <div class="deliverable-text">
            <h3>Solutions buyers will pay for</h3>
            <p>What should we build?</p>
          </div>
          <div class="deliverable-graphic"></div>
        </div>
        <div class="deliverable">
          <div class="deliverable-text">
            <h3>Attractive buyer segments</h3>
            <p>Who do we target?</p>
          </div>
          <div class="deliverable-graphic"></div>
        </div>
        <div class="deliverable">
          <div class="deliverable-text">
            <h3>What buyers think of brands</h3>
            <p>What is our messaging?</p>
          </div>
          <div class="deliverable-graphic"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- 5. Who's Behind It — paper background -->
  <section class="section" id="about">
    <div class="container">
      <span class="eyebrow">Who's behind it</span>
      <h2 class="section-heading section-heading--wide">Decades of academic and industry experience.</h2>

      <div class="about-grid">
        <div class="about-sidebar">
          <div class="about-photo-wrap">
            <img src="/images/forest-baker.jpg" alt="Forest Baker, PhD" class="about-photo" width="180" height="180" loading="lazy" />
          </div>
          <a href="https://www.linkedin.com/in/forestb/" target="_blank" rel="noopener noreferrer" class="about-linkedin">LinkedIn profile <span class="external-icon" aria-hidden="true">&#8599;</span></a>
        </div>
        <div class="about-bio">
          <h3>Forest Baker, PhD, MBA</h3>
          <p class="about-title">Founder and CEO</p>

          <p class="about-section-head">Career highlights</p>

          <p class="eyebrow about-category">Academia</p>
          <ul class="about-list">
            <li>MBA, Duke University</li>
            <li>PhD in Experimental Psychology, SUNY Stony Brook</li>
            <li>Postdoctoral Fellow in Behavioral Economics, University of Vermont</li>
            <li>Assistant Professor of Psychology, Illinois Wesleyan University</li>
            <li>2,200+ research citations</li>
          </ul>

          <p class="eyebrow about-category">Industry</p>
          <ul class="about-list">
            <li>Maze: UX Research Sales</li>
            <li>LinkedIn: Led a global insights team and launched ad measurement program</li>
            <li>Abbott Vascular Devices: Market research and product management</li>
            <li>Dept of Veterans Affairs: Health Economics Researcher</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer — dark -->
  <footer class="footer">
    <div class="container">
      <div class="footer-inner">
        <a href="/" class="footer-logo" aria-label="BuyerVoice.AI home">
          <img src="/images/logo.svg" alt="BuyerVoice.AI" width="160" height="32" />
        </a>
        <div class="footer-links">
          <a href="#deliverables">Services</a>
          <a href="#method">Methodology</a>
          <a href="#about">About</a>
        </div>
      </div>
      <p class="footer-copy">&copy; 2026 BuyerVoice.AI. All rights reserved.</p>
    </div>
  </footer>
</Base>

<style>
  /* Nav */
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(247, 245, 239, 0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(11, 31, 58, 0.06);
  }

  .nav-inner {
    max-width: var(--container);
    margin: 0 auto;
    padding: 1rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-logo {
    text-decoration: none;
    display: inline-flex;
  }

  .nav-logo img {
    height: 60px;
    width: auto;
  }

  .nav-links {
    display: flex;
    gap: 2.25rem;
    align-items: center;
  }

  .nav-link {
    font-family: var(--sans);
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--ink);
    text-decoration: none;
    letter-spacing: 0.01em;
    position: relative;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 1.5px;
    background: var(--signal);
    transition: width 0.25s ease;
  }

  .nav-link:hover {
    color: var(--signal);
  }

  .nav-link:hover::after {
    width: 100%;
  }

  /* Container */
  .container {
    max-width: var(--container);
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* Hero — paper background (default) */
  .hero {
    padding-top: clamp(120px, 16vw, 180px);
    padding-bottom: var(--section-gap);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 38% 60%;
    gap: 2%;
    align-items: center;
  }

  .hero-copy {
    min-width: 0;
  }

  .hero-headline {
    font-size: clamp(2.2rem, 4.5vw, 3.2rem);
    line-height: 1.06;
    font-weight: 700;
    letter-spacing: -0.025em;
    text-wrap: balance;
  }

  .hero-sub {
    margin-top: 1.5rem;
    font-size: 1.05rem;
    line-height: 1.65;
    color: var(--muted);
    max-width: 38ch;
  }

  .hero-rule {
    width: 48px;
    height: 2px;
    background: var(--signal);
    margin-top: 2.5rem;
  }

  .hero-illustration {
    display: flex;
    justify-content: flex-end;
  }

  .hero-illustration img {
    width: 100%;
    height: auto;
  }

  /* Section bands */
  .section {
    padding: var(--section-gap) 0;
  }

  .band-dark {
    padding: var(--section-gap) 0;
    background: var(--ink);
    color: rgba(255, 255, 255, 0.8);
  }

  .band-warm {
    padding: var(--section-gap) 0;
    background: #EDE9DF;
  }

  /* Section typography */
  .section-heading {
    font-size: clamp(1.6rem, 3.5vw, 2.2rem);
    line-height: 1.18;
    margin-top: 0.75rem;
    max-width: 26ch;
    text-wrap: balance;
  }

  .section-heading--wide {
    max-width: none;
  }

  .heading--light {
    color: #fff;
  }

  .eyebrow--light {
    color: rgba(255, 255, 255, 0.5);
  }

  .section-intro {
    margin-top: 1.25rem;
    color: var(--muted);
    max-width: 60ch;
    line-height: 1.65;
  }

  /* Stats cards (problem section) */
  .stats-grid {
    margin-top: 3rem;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .stat-card {
    background: rgba(255, 255, 255, 0.08);
    border-radius: 6px;
    padding: 2.25rem 2rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
  }

  .stat-context {
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.65);
    line-height: 1.5;
  }

  .stat-context strong {
    color: #fff;
  }

  .stat-number {
    font-family: var(--serif);
    font-size: clamp(3.5rem, 7vw, 5rem);
    font-weight: 700;
    color: var(--signal);
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin: 0.5rem 0;
  }

  .stat-detail {
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.65);
    line-height: 1.5;
    max-width: 26ch;
  }

  .stat-detail strong {
    color: #fff;
  }

  .stat-source {
    margin-top: auto;
    padding-top: 1rem;
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.35);
    letter-spacing: 0.02em;
  }

  /* Method — capabilities (paper background) */
  .method-capabilities {
    margin-top: 3rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
  }

  .capability {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
    padding: 2rem 2.25rem;
    border-bottom: 1px solid rgba(11, 31, 58, 0.08);
    border-right: 1px solid rgba(11, 31, 58, 0.08);
  }

  .capability:nth-child(2n) {
    border-right: none;
  }

  .capability:nth-child(n+3) {
    border-bottom: none;
  }

  .capability-number {
    font-family: var(--serif);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--signal);
    flex-shrink: 0;
    line-height: 1;
    min-width: 1.5rem;
    margin-top: 0.15rem;
  }

  .capability p {
    font-family: var(--serif);
    font-size: 1.15rem;
    font-weight: 500;
    line-height: 1.45;
    color: var(--ink);
    letter-spacing: -0.01em;
  }

  /* Deliverables (warm band) */
  .deliverables-list {
    margin-top: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .deliverable {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    align-items: center;
    padding: 2rem 2.5rem;
    background: #fff;
    border-radius: 6px;
    box-shadow: 0 1px 3px rgba(11, 31, 58, 0.05);
  }

  .deliverable h3 {
    font-size: 1.15rem;
    font-weight: 600;
    margin-bottom: 0.35rem;
  }

  .deliverable p {
    font-size: 1rem;
    font-style: italic;
    line-height: 1.5;
    color: var(--muted);
  }

  .deliverable-graphic {
    min-height: 80px;
  }

  /* About */
  .about-grid {
    margin-top: 2.5rem;
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 3rem;
    align-items: start;
  }

  .about-sidebar {
    display: flex;
    flex-direction: column;
  }

  .about-photo-wrap {
    position: relative;
    margin-bottom: 1.25rem;
  }

  .about-photo {
    width: 180px;
    height: 180px;
    object-fit: cover;
    object-position: top center;
    border-radius: 50%;
    filter: grayscale(15%);
  }

  .about-linkedin {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--signal);
    text-decoration: none;
  }

  .about-linkedin:hover {
    text-decoration: underline;
  }

  .external-icon {
    font-size: 0.75rem;
  }

  .about-bio h3 {
    font-family: var(--serif);
    font-size: 1.6rem;
    font-weight: 600;
    line-height: 1.2;
  }

  .about-title {
    margin-top: 0.25rem;
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--signal);
  }

  .about-section-head {
    margin-top: 1.75rem;
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--ink);
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(11, 31, 58, 0.08);
  }

  .about-category {
    margin-top: 1.25rem;
    margin-bottom: 0.5rem;
  }

  .about-list {
    list-style: none;
    padding-left: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .about-list li {
    font-size: 0.92rem;
    line-height: 1.55;
    color: var(--rule);
    padding-left: 1rem;
    position: relative;
  }

  .about-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--signal);
  }

  /* Footer — dark */
  .footer {
    padding: 3rem 0;
    background: var(--ink);
    color: rgba(255, 255, 255, 0.5);
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-bottom: 2rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    margin-bottom: 1.5rem;
  }

  .footer-logo {
    text-decoration: none;
    display: inline-flex;
  }

  .footer-logo img {
    height: 28px;
    width: auto;
    filter: brightness(0) invert(1);
    opacity: 0.7;
  }

  .footer-copy {
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.4);
  }

  .footer-links {
    display: flex;
    gap: 2rem;
  }

  .footer-links a {
    font-size: 0.82rem;
    color: rgba(255, 255, 255, 0.5);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer-links a:hover {
    color: #fff;
  }

  /* Responsive */
  @media (max-width: 960px) {
    .method-capabilities {
      grid-template-columns: 1fr;
    }

    .capability {
      border-right: none;
    }

    .capability:nth-child(3) {
      border-bottom: 1px solid rgba(11, 31, 58, 0.08);
    }

    .deliverable {
      grid-template-columns: 1fr;
    }

    .stats-grid {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }
  }

  @media (max-width: 768px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .hero-illustration {
      max-width: 500px;
    }

    .hero-headline {
      font-size: clamp(2rem, 7vw, 2.6rem);
    }
  }

  @media (max-width: 640px) {
    .nav-links {
      gap: 1.25rem;
    }

    .nav-link {
      font-size: 0.8rem;
    }

    .about-grid {
      grid-template-columns: 1fr;
    }

    .about-photo {
      width: 140px;
      height: 140px;
    }

    .footer-inner {
      flex-direction: column;
      gap: 1rem;
      text-align: center;
    }
  }
</style>
