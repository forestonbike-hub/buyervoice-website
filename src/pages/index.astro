              <circle cx="190" cy="18" r="6" fill="#B8341B" opacity="0.6"/>
              <text x="202" y="23" font-family="var(--sans)" font-size="13" fill="#0B1F3A">Current customers' perceptions</text>

              <!-- Subtitle -->
              <text x="0" y="50" font-family="var(--sans)" font-size="11" fill="#6B6B6B" font-style="italic">n=180 (60 per tool). Positives only.</text>

              <!-- Dashed axes (more visible) -->
