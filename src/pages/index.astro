---
import Base from '../layouts/Base.astro';
---

<Base
  title="BuyerVoice.AI — Buyer insights from real conversations"
  description="Hundreds of interviews. Market intelligence for marketing, product, and sales teams."
>
  <!-- Nav -->
  <nav class="nav" aria-label="Primary navigation">
    <div class="nav-inner">
      <a href="/" class="nav-logo" aria-label="BuyerVoice.AI home">
        <img src="/images/logo.svg" alt="BuyerVoice.AI" width="240" height="48" />
      </a>
      <div class="nav-links">
        <a href="#deliverables" class="nav-link">Services</a>
        <a href="#method" class="nav-link">Methodology</a>
        <a href="#about" class="nav-link">About</a>
      </div>
    </div>
  </nav>

  <!-- 1. Hero -->
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <h1 class="hero-headline">Buyer insights from real conversations.</h1>
        <p class="hero-sub">
          Hundreds of interviews. Market intelligence for marketing, product, and sales teams.
        </p>
        <div class="hero-rule"></div>
      </div>
      <div class="hero-illustration">
        <img src="/images/hero-illustration.svg" alt="Interview data visualization showing patterns across hundreds of buyer conversations" width="700" height="400" loading="eager" />
      </div>
    </div>
  </section>

  <!-- 2. The Problem — dark band -->
  <section class="band-dark" id="problem">
    <div class="container">
      <span class="eyebrow eyebrow--light">The problem</span>
      <h2 class="section-heading heading--light section-heading--wide">Flying blind is the norm, and costly.</h2>

      <div class="stats-grid">
        <div class="stat-card">
          <p class="stat-context">Among 353 startups,</p>
          <p class="stat-number">42%</p>
          <p class="stat-detail">of <strong>product failures</strong> traced to "no market need"</p>
          <p class="stat-source">CB Insights</p>
        </div>

        <div class="stat-card">
          <p class="stat-context">Among 1,600 companies,</p>
          <p class="stat-number">80%</p>
          <p class="stat-detail"><strong>did not</strong> have pricing discussions with customers early in product development</p>
          <p class="stat-source">Simon-Kucher &amp; Partners</p>
        </div>

        <div class="stat-card">
          <p class="stat-context">Companies <strong>without</strong> strong insights capabilities are</p>
          <p class="stat-number">88%</p>
          <p class="stat-detail"><strong>less likely</strong> to achieve strong revenue growth</p>
          <p class="stat-source">Forrester</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. Our Method — paper background -->
  <section class="section" id="method">
    <div class="container">
      <span class="eyebrow">Our method</span>
      <h2 class="section-heading">Three steps. Hundreds of conversations. One clear answer.</h2>

      <div class="method-grid">
        <div class="method-card">
          <span class="method-number">01</span>
          <h3 class="method-title">Interview at scale.</h3>
          <p>
            AI-moderated interviews run hundreds of structured conversations with buyers, switchers, and non-customers in your category. Each one follows a research-grade guide. Each one probes on follow-ups a survey never could.
          </p>
        </div>

        <div class="method-card">
          <span class="method-number">02</span>
          <h3 class="method-title">Anchor on the switch.</h3>
          <p>
            Every study centers on the buyer's last real decision in the category. What they considered, what they picked, what they regret. Switching analysis reveals the actual decision logic of your market, not a hypothetical ranking of features.
          </p>
        </div>

        <div class="method-card">
          <span class="method-number">03</span>
          <h3 class="method-title">Analyze with marketing science.</h3>
          <p>
            Transcripts are coded and analyzed using established frameworks: category entry points, jobs-to-be-done, perceived differentiation, switching cost models. The output is a structured finding, not a stack of highlighted quotes.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. What You Get — warm tint band -->
  <section class="band-warm" id="deliverables">
    <div class="container">
      <span class="eyebrow">What you get</span>
      <h2 class="section-heading">A finished answer, not a data dump.</h2>
      <p class="section-intro">
        Every engagement produces deliverables designed to move directly into your marketing, product, and sales workflows. No dashboards. No raw transcripts dropped over the wall.
      </p>

      <div class="deliverables-grid">
        <div class="deliverable">
          <div class="deliverable-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><rect x="3" y="4" width="22" height="20" rx="2" stroke="currentColor" stroke-width="1.5"/><line x1="8" y1="10" x2="20" y2="10" stroke="currentColor" stroke-width="1.5"/><line x1="8" y1="14" x2="17" y2="14" stroke="currentColor" stroke-width="1.5"/><line x1="8" y1="18" x2="14" y2="18" stroke="currentColor" stroke-width="1.5"/></svg>
          </div>
          <h3>Narrative report</h3>
          <p>A structured account of how your market perceives your category, grounded in hundreds of real conversations. Written for executives, not academics.</p>
        </div>
        <div class="deliverable">
          <div class="deliverable-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><circle cx="9" cy="10" r="3" stroke="currentColor" stroke-width="1.5"/><circle cx="19" cy="10" r="3" stroke="currentColor" stroke-width="1.5"/><circle cx="14" cy="20" r="3" stroke="currentColor" stroke-width="1.5"/><line x1="11" y1="12" x2="13" y2="18" stroke="currentColor" stroke-width="1.5"/><line x1="17" y1="12" x2="15" y2="18" stroke="currentColor" stroke-width="1.5"/><line x1="12" y1="10" x2="16" y2="10" stroke="currentColor" stroke-width="1.5"/></svg>
          </div>
          <h3>Switching map</h3>
          <p>A visual model of how buyers move between solutions in your category. What triggers consideration, what closes the deal, what causes regret.</p>
        </div>
        <div class="deliverable">
          <div class="deliverable-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M6 8h16v14H6z" stroke="currentColor" stroke-width="1.5" rx="1"/><line x1="6" y1="12" x2="22" y2="12" stroke="currentColor" stroke-width="1.5"/><line x1="14" y1="12" x2="14" y2="22" stroke="currentColor" stroke-width="1.5"/></svg>
          </div>
          <h3>Persona-language library</h3>
          <p>The actual words your buyers use to describe their problems, evaluate alternatives, and justify decisions. Organized by persona and buying stage.</p>
        </div>
        <div class="deliverable">
          <div class="deliverable-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M14 5l3 6h6l-5 4 2 7-6-4-6 4 2-7-5-4h6z" stroke="currentColor" stroke-width="1.5" fill="none"/></svg>
          </div>
          <h3>Specific recommendations</h3>
          <p>Concrete actions for marketing, product, and sales, each tied to a finding in the data. Not "consider repositioning." Instead: here is the positioning, here is the evidence, here is who it resonates with.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 5. Who's Behind It — paper background -->
  <section class="section" id="about">
    <div class="container">
      <span class="eyebrow">Who's behind it</span>
      <h2 class="section-heading section-heading--wide">Decades of academic and industry experience.</h2>

      <div class="about-grid">
        <div class="about-sidebar">
          <div class="about-photo-wrap">
            <img src="/images/forest-baker.jpg" alt="Forest Baker, PhD" class="about-photo" width="180" height="180" loading="lazy" />
          </div>
          <a href="https://www.linkedin.com/in/forestb/" target="_blank" rel="noopener noreferrer" class="about-linkedin">LinkedIn profile <span class="external-icon" aria-hidden="true">&#8599;</span></a>
        </div>
        <div class="about-bio">
          <h3>Forest Baker, PhD, MBA</h3>
          <p class="about-title">Founder and CEO</p>

          <p class="about-section-head">Career highlights</p>

          <p class="eyebrow about-category">Academia</p>
          <ul class="about-list">
            <li>MBA, Duke University</li>
            <li>PhD in Experimental Psychology, SUNY Stony Brook</li>
            <li>Postdoctoral Fellow in Behavioral Economics, University of Vermont</li>
            <li>Assistant Professor of Psychology, Illinois Wesleyan University</li>
            <li>2,200+ research citations</li>
          </ul>

          <p class="eyebrow about-category">Industry</p>
          <ul class="about-list">
            <li>LinkedIn: Led a global insights team and launched ad measurement program</li>
            <li>Abbott Vascular Devices: Market research and product management</li>
            <li>Dept of Veterans Affairs: Health Economics Researcher</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer — dark -->
  <footer class="footer">
    <div class="container">
      <div class="footer-inner">
        <a href="/" class="footer-logo" aria-label="BuyerVoice.AI home">
          <img src="/images/logo.svg" alt="BuyerVoice.AI" width="160" height="32" />
        </a>
        <div class="footer-links">
          <a href="#deliverables">Services</a>
          <a href="#method">Methodology</a>
          <a href="#about">About</a>
        </div>
      </div>
      <p class="footer-copy">&copy; 2026 BuyerVoice.AI. All rights reserved.</p>
    </div>
  </footer>
</Base>

<style>
  /* Nav */
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(247, 245, 239, 0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(11, 31, 58, 0.06);
  }

  .nav-inner {
    max-width: var(--container);
    margin: 0 auto;
    padding: 1rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-logo {
    text-decoration: none;
    display: inline-flex;
  }

  .nav-logo img {
    height: 40px;
    width: auto;
  }

  .nav-links {
    display: flex;
    gap: 2.25rem;
    align-items: center;
  }

  .nav-link {
    font-family: var(--sans);
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--ink);
    text-decoration: none;
    letter-spacing: 0.01em;
    position: relative;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 1.5px;
    background: var(--signal);
    transition: width 0.25s ease;
  }

  .nav-link:hover {
    color: var(--signal);
  }

  .nav-link:hover::after {
    width: 100%;
  }

  /* Container */
  .container {
    max-width: var(--container);
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* Hero — paper background (default) */
  .hero {
    padding-top: clamp(120px, 16vw, 180px);
    padding-bottom: var(--section-gap);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 38% 60%;
    gap: 2%;
    align-items: center;
  }

  .hero-copy {
    min-width: 0;
  }

  .hero-headline {
    font-size: clamp(2.2rem, 4.5vw, 3.2rem);
    line-height: 1.06;
    font-weight: 700;
    letter-spacing: -0.025em;
    text-wrap: balance;
  }

  .hero-sub {
    margin-top: 1.5rem;
    font-size: 1.05rem;
    line-height: 1.65;
    color: var(--muted);
    max-width: 38ch;
  }

  .hero-rule {
    width: 48px;
    height: 2px;
    background: var(--signal);
    margin-top: 2.5rem;
  }

  .hero-illustration {
    display: flex;
    justify-content: flex-end;
  }

  .hero-illustration img {
    width: 100%;
    height: auto;
  }

  /* Section bands */
  .section {
    padding: var(--section-gap) 0;
  }

  .band-dark {
    padding: var(--section-gap) 0;
    background: var(--ink);
    color: rgba(255, 255, 255, 0.8);
  }

  .band-warm {
    padding: var(--section-gap) 0;
    background: #EDE9DF;
  }

  /* Section typography */
  .section-heading {
    font-size: clamp(1.6rem, 3.5vw, 2.2rem);
    line-height: 1.18;
    margin-top: 0.75rem;
    max-width: 26ch;
    text-wrap: balance;
  }

  .section-heading--wide {
    max-width: none;
  }

  .heading--light {
    color: #fff;
  }

  .eyebrow--light {
    color: rgba(255, 255, 255, 0.5);
  }

  .section-intro {
    margin-top: 1.25rem;
    color: var(--muted);
    max-width: 60ch;
    line-height: 1.65;
  }

  /* Stats cards (problem section) */
  .stats-grid {
    margin-top: 3rem;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .stat-card {
    background: rgba(255, 255, 255, 0.08);
    border-radius: 6px;
    padding: 2.25rem 2rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
  }

  .stat-context {
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.65);
    line-height: 1.5;
  }

  .stat-context strong {
    color: #fff;
  }

  .stat-number {
    font-family: var(--serif);
    font-size: clamp(3.5rem, 7vw, 5rem);
    font-weight: 700;
    color: var(--signal);
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin: 0.5rem 0;
  }

  .stat-detail {
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.65);
    line-height: 1.5;
    max-width: 26ch;
  }

  .stat-detail strong {
    color: #fff;
  }

  .stat-source {
    margin-top: auto;
    padding-top: 1rem;
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.35);
    letter-spacing: 0.02em;
  }

  /* Method (paper background) */
  .method-grid {
    margin-top: 3rem;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .method-card {
    padding: 2rem 1.75rem;
    background: #fff;
    border-radius: 6px;
    box-shadow: 0 1px 3px rgba(11, 31, 58, 0.06), 0 4px 16px rgba(11, 31, 58, 0.04);
    transition: box-shadow 0.25s ease, transform 0.25s ease;
  }

  .method-card:hover {
    box-shadow: 0 2px 8px rgba(11, 31, 58, 0.08), 0 8px 28px rgba(11, 31, 58, 0.06);
    transform: translateY(-2px);
  }

  .method-number {
    font-family: var(--serif);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--signal);
    letter-spacing: 0.05em;
    display: block;
    margin-bottom: 1.25rem;
  }

  .method-title {
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
  }

  .method-card p {
    font-size: 0.95rem;
    line-height: 1.65;
    color: var(--muted);
  }

  /* Deliverables (warm band) */
  .deliverables-grid {
    margin-top: 2.5rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .deliverable {
    padding: 2rem;
    background: #fff;
    border-radius: 6px;
    box-shadow: 0 1px 3px rgba(11, 31, 58, 0.05);
    transition: box-shadow 0.25s ease, transform 0.25s ease;
  }

  .deliverable:hover {
    box-shadow: 0 2px 8px rgba(11, 31, 58, 0.08), 0 6px 20px rgba(11, 31, 58, 0.04);
    transform: translateY(-2px);
  }

  .deliverable-icon {
    color: var(--signal);
    margin-bottom: 1rem;
  }

  .deliverable h3 {
    font-size: 1.05rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .deliverable p {
    font-size: 0.95rem;
    line-height: 1.65;
    color: var(--muted);
  }

  /* About */
  .about-grid {
    margin-top: 2.5rem;
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 3rem;
    align-items: start;
  }

  .about-sidebar {
    display: flex;
    flex-direction: column;
  }

  .about-photo-wrap {
    position: relative;
    margin-bottom: 1.25rem;
  }

  .about-photo {
    width: 180px;
    height: 180px;
    object-fit: cover;
    object-position: top center;
    border-radius: 50%;
    filter: grayscale(15%);
  }

  .about-linkedin {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--signal);
    text-decoration: none;
  }

  .about-linkedin:hover {
    text-decoration: underline;
  }

  .external-icon {
    font-size: 0.75rem;
  }

  .about-bio h3 {
    font-family: var(--serif);
    font-size: 1.6rem;
    font-weight: 600;
    line-height: 1.2;
  }

  .about-title {
    margin-top: 0.25rem;
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--signal);
  }

  .about-section-head {
    margin-top: 1.75rem;
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--ink);
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(11, 31, 58, 0.08);
  }

  .about-category {
    margin-top: 1.25rem;
    margin-bottom: 0.5rem;
  }

  .about-list {
    list-style: none;
    padding-left: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .about-list li {
    font-size: 0.92rem;
    line-height: 1.55;
    color: var(--rule);
    padding-left: 1rem;
    position: relative;
  }

  .about-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--signal);
  }

  /* Footer — dark */
  .footer {
    padding: 3rem 0;
    background: var(--ink);
    color: rgba(255, 255, 255, 0.5);
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-bottom: 2rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    margin-bottom: 1.5rem;
  }

  .footer-logo {
    text-decoration: none;
    display: inline-flex;
  }

  .footer-logo img {
    height: 28px;
    width: auto;
    filter: brightness(0) invert(1);
    opacity: 0.7;
  }

  .footer-copy {
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.4);
  }

  .footer-links {
    display: flex;
    gap: 2rem;
  }

  .footer-links a {
    font-size: 0.82rem;
    color: rgba(255, 255, 255, 0.5);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer-links a:hover {
    color: #fff;
  }

  /* Responsive */
  @media (max-width: 960px) {
    .method-grid {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }

    .deliverables-grid {
      grid-template-columns: 1fr;
    }

    .stats-grid {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }
  }

  @media (max-width: 768px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .hero-illustration {
      max-width: 500px;
    }

    .hero-headline {
      font-size: clamp(2rem, 7vw, 2.6rem);
    }
  }

  @media (max-width: 640px) {
    .nav-links {
      gap: 1.25rem;
    }

    .nav-link {
      font-size: 0.8rem;
    }

    .about-grid {
      grid-template-columns: 1fr;
    }

    .about-photo {
      width: 140px;
      height: 140px;
    }

    .footer-inner {
      flex-direction: column;
      gap: 1rem;
      text-align: center;
    }
  }
</style>
