        <div class="deliverable">
          <div class="deliverable-text">
            <h3>What buyers think of brands</h3>
            <p>What is our messaging?</p>
          </div>
          <div class="deliverable-graphic">
            <svg viewBox="0 0 740 560" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Correspondence analysis map showing why buyers reject brands">
              <!-- Legend -->
              <circle cx="30" cy="18" r="8" fill="#0B1F3A" opacity="0.7"/>
